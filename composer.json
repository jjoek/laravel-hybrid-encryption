{
    "name": "jjoek/laravel-hybrid-encryption",
    "description": "Laravel package for hybrid encryption (RSA-OAEP + AES-256-GCM) for secure API request handling",
    "keywords": ["laravel", "encryption", "rsa", "aes", "hybrid-encryption", "security", "api"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "JJoek",
            "email": "dev@jjoek.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "ext-openssl": "*"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Jjoek\\HybridEncryption\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jjoek\\HybridEncryption\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jjoek\\HybridEncryption\\HybridEncryptionServiceProvider"
            ],
            "aliases": {
                "HybridEncryption": "Jjoek\\HybridEncryption\\Facades\\HybridEncryption"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
